# === OpenWA (EASY API) ===
# Clé qui protège l'API REST locale d'OpenWA (sendText, etc.). Mets une valeur longue/aléatoire.
OPENWA_API_KEY=change-me-long-random-string
# Port de l'API REST OpenWA
OPENWA_PORT=8002
# Licence Insiders OpenWA (optionnel, pour médias & features avancées)
OPENWA_LICENSE_KEY=

# === zeroclaw ===
# URL du webhook entrant exposé par zeroclaw (OpenWA y poste les messages)
ZEROCLAW_WEBHOOK_URL=http://127.0.0.1:42617/webhook/whatsapp
# Secret partagé, vérifié par zeroclaw sur le webhook entrant
TROT_WEBHOOK_SECRET=change-me-shared-secret
# URL de l'API REST OpenWA que zeroclaw rappelle pour ENVOYER les réponses
OPENWA_API_URL=http://127.0.0.1:8002

# === Calendrier (Option B : ajout autonome via CalDAV — iCloud / Google / Fastmail) ===
# Optionnel. Seulement si tu veux que zeroclaw ajoute des événements SANS passer par l'iPhone.
# Voir docs/calendrier.md pour trouver l'URL de collection et créer un mot de passe d'application.
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=

# === Garde-fous ===
# Numéros autorisés à déclencher des réponses auto (séparés par des virgules, format international).
# Vide = tout le monde. Recommandé : restreindre en phase de test.
ALLOWED_NUMBERS=
